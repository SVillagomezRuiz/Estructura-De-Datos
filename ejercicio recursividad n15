#include <iostream>
#include <string>

using namespace std;

int convertir(string num, int base, int n);

int main() {
    string numero;
    int base;

    cout << "Ingrese el numero: ";
    cin >> numero;

    cout << "Ingrese la base: ";
    cin >> base;

    cout << "En decimal es: " 
         << convertir(numero, base, numero.length());

    return 0;
}

int convertir(string num, int base, int n) {

    if (n == 0) 
        return 0;
    else {
        int digito;

        if (num[n-1] >= '0' && num[n-1] <= '9')
            digito = num[n-1] - '0';
        else
            digito = num[n-1] - 'A' + 10;

        return convertir(num, base, n-1) * base + digito;
    }
}
